    LOCAL :p
    BINARY :add
    DEREF
    STORE
    PUSH 5
    PUSH 0
    LOCAL :p
    BINARY :add
    DEREF
    BINARY :add
    PUSH 1
    LOCAL :p
    BINARY :add
    DEREF
    STORE
    PUSH 0
    LOCAL :p
    BINARY :add
    DEREF
    INSPECT
    PUSH 1
