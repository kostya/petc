FUNC :fib
  ARGS
    TYPE :i32
  RETURN
    TYPE :i32
  BODY
    PUSH 1
    PARAM 0
    BINARY :less_eq
    IF
      THEN
        PARAM 0
        RET
    ENDIF
    PUSH 1
    PARAM 0
    BINARY :sub
    CALL :fib
    PUSH 2
    PARAM 0
    BINARY :sub
    CALL :fib
    BINARY :add
    RET
ENDFUNC

FUNC :main
  BODY
    PUSH 10
    CALL :fib
    INSPECT
ENDFUNC

