FUNC :fact
  ARGS
    TYPE :i32
  RETURN
    TYPE :i32
  BODY
    PUSH 1
    PARAM 0
    BINARY :less_eq
    IF
      THEN
        PUSH 1
        RET
    ENDIF
    PUSH 1
    PARAM 0
    BINARY :sub
    CALL :fact
    PARAM 0
    BINARY :mul
    RET
ENDFUNC

FUNC :main
  BODY
    PUSH 5
    CALL :fact
    INSPECT
ENDFUNC

