FUNC :main
  BODY
    PUSH 4
    MALLOC :u8
    LOCAL :p :ptr<u8>
    STORE
    PUSH 255
    AS :u8
    PUSH 0
    LOCAL :p
    BINARY :add
    DEREF
    STORE
    PUSH 1
    AS :u8
    PUSH 1
    LOCAL :p
    BINARY :add
    DEREF
    STORE
    PUSH 0
    LOCAL :p
    BINARY :add
    DEREF
    INSPECT
    PUSH 1
    LOCAL :p
    BINARY :add
    DEREF
    INSPECT
    LOCAL :p
    AS :ptr<void>
    CALL :free
ENDFUNC

