{{general.myc_include}}

FUNC :show
  ARGS
    TYPE :ptr<EnumTest>
  BODY
    PARAM 0
    DEREF
    INSPECT
ENDFUNC

FUNC :main
  BODY
    LOOP
      INIT
        PUSH 0
        LOCAL :x :i32
        STORE
      COND
        PUSH 11
        LOCAL :x
        BINARY :less
      BODY
        LOCAL :x
        CALL :EnumTest_create
        LOCAL :var :EnumTest
        STORE
        LOCAL :var
        ADDR
        CALL :show
      STEP
        PUSH 1
        LOCAL :x
        BINARY :add
        LOCAL :x
        STORE
    ENDLOOP
ENDFUNC

