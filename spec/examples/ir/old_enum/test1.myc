{{general.myc_include}}

FUNC :main
  BODY
    LOOP
      INIT
        PUSH 0
        LOCAL :x :i32
        STORE
      COND
        PUSH 11
        LOCAL :x
        BINARY :less
      BODY
        LOCAL :x
        CALL :EnumTest_create
        INSPECT
      STEP
        PUSH 1
        LOCAL :x
        BINARY :add
        LOCAL :x
        STORE
    ENDLOOP
ENDFUNC

