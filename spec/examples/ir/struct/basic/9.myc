STRUCT :Point
  TYPE :i32
  TYPE :i32
ENDSTRUCT

FUNC :make_point
  RETURN
    TYPE :Point
  BODY
    PUSH 42
    LOCAL :p :Point
    FIELD 0
    STORE
    PUSH 99
    LOCAL :p
    FIELD 1
    STORE
    LOCAL :p
    RET
ENDFUNC

FUNC :main
  BODY
    CALL :make_point
    LOCAL :result :Point
    STORE
    LOCAL :result
    FIELD 0
    INSPECT
    LOCAL :result
    FIELD 1
    INSPECT
ENDFUNC

