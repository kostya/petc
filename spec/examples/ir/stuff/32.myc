FLAT :flat
  TYPE :u8
  COUNT 8
ENDFLAT

STRUCT :Option
  TYPE :i32
  TYPE :flat
ENDSTRUCT

GLOBAL :go
  TYPE :Option
ENDGLOBAL

FUNC :main
  BODY
    PUSH 42
    GLOBAL :go
    FIELD 1
    AS :i32
    STORE
    PUSH 1
    GLOBAL :go
    FIELD 0
    STORE
    GLOBAL :go
    FIELD 0
    INSPECT
    GLOBAL :go
    FIELD 1
