FUNC :main
  BODY
    PUSH 0
    LOCAL :i :i32
    STORE
    LOOP
      COND
        PUSH 5
        LOCAL :i
        BINARY :less
      BODY
        PUSH 2
        LOCAL :i
        BINARY :rem
        PUSH 0
        BINARY :eq
        IF
          THEN
            NEXT
        ENDIF
        LOCAL :i
        INSPECT
      STEP
        PUSH 1
        LOCAL :i
        BINARY :add
        LOCAL :i
        STORE
    ENDLOOP
ENDFUNC

