STRUCT :Point
  TYPE :i32
  TYPE :i32
ENDSTRUCT

FUNC :init_point
  ARGS
    TYPE :ptr<Point>
  BODY
    PUSH 10
    PARAM 0
    DEREF
    FIELD 0
    STORE
    PUSH 20
    PARAM 0
    DEREF
    FIELD 1
    STORE
ENDFUNC

FUNC :main
  BODY
    LOCAL :p :Point
    ADDR
    CALL :init_point
    LOCAL :p
    INSPECT
ENDFUNC

