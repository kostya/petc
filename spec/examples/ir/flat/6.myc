FLAT :bla
  TYPE :i32
  COUNT 3
ENDFLAT

FUNC :test
  ARGS
    TYPE :ptr<bla>
  BODY
    PUSH 42
    PARAM 0
    DEREF
    FIELD 1
    STORE
ENDFUNC

FUNC :main
  BODY
    PUSH 3
    PUSH 2
    PUSH 1
    CREATE :bla
    LOCAL :x :bla
    STORE
    LOCAL :x
    ADDR
    CALL :test
    LOCAL :x
    INSPECT
ENDFUNC

