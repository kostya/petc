FUNC :main
  RETURN
    TYPE :i32
  BODY
    PUSH 30 :i32
    PUSH 20 :i32
    PUSH 10 :i32
    CREATE "flat<i32, 3>"
    LOCAL :x "flat<i32, 3>"
    STORE
    PUSH 42
    LOCAL :x
    ADDR
    AS :ptr<i32>
    PUSH 1
    STACK :swap2
    BINARY :add
    DEREF
    STORE
    LOCAL :x
    INSPECT
    PUSH 0
    RET
ENDFUNC

